func twoSum(nums []int, target int) []int {
    var length int = len(nums)
    ans := make([]int,2)
    for i:=0;i<length;i++ {
        for j:=i+1;j<length;j++ {
            if nums[i]+nums[j]==target {
                ans[0] = i
                ans[1] = j;
                break;
            }
        }
    }
    return ans
}
