package main

import "fmt"

func factorial(n int) int {
	fact := 1
	for i := 1; i <= n; i++ {
		fact *= i
	}
	return fact
}

func isStrong(num int) bool {
	original := num
	sum := 0

	for num > 0 {
		digit := num % 10
		sum += factorial(digit)
		num /= 10
	}

	return sum == original
}

func main() {
	var num int

	fmt.Print("Enter a number: ")
	fmt.Scan(&num)

	if isStrong(num) {
		fmt.Println(num, "is a Strong Number")
	} else {
		fmt.Println(num, "is Not a Strong Number")
	}
}
